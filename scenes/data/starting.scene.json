{
  "id": "starting",
  "background": { "component": "DotGridBackground", "options": { "mode": "starting" } },
  "transition": { "type": "crossfade", "duration": 500, "easing": "easeInOut" },
  "layers": [
    {
      "name": "goldbar",
      "components": [
        { "component": "GoldBar", "options": { "position": "top" } },
        { "component": "GoldBar", "options": { "position": "bottom" } }
      ],
      "visibility": { "full": true, "minimal": true, "hidden": false }
    },
    {
      "name": "message",
      "components": [
        { "component": "TextLabel", "options": { "text": "— Démarrage imminent —", "className": "starting-tag label-mono wide" } },
        { "component": "TextLabel", "options": { "text": "D0n", "className": "starting-name heading-serif", "tag": "h1" } },
        { "component": "Divider", "options": { "className": "starting-rule-gold rule-h-gold" } },
        { "component": "TextLabel", "options": { "text": "Au programme aujourd'hui — surprise.", "className": "starting-subject-text value-serif" } }
      ],
      "visibility": { "full": true, "minimal": true, "hidden": false }
    },
    {
      "name": "links",
      "components": [
        { "component": "TextList", "options": { "lines": { "$bind": "socialLinks" }, "itemClass": "starting-link-item value-mono-gold" } }
      ],
      "visibility": { "full": true, "minimal": false, "hidden": false }
    }
  ]
}
