        { "component": "TextLabel", "options": { "text": { "$bind": "currentBranch", "$default": "" }, "className": "git-branch value-mono-gold" }, "placement": { "x": 0, "y": 77 } },
        { "component": "TextLabel", "options": { "text": { "$bind": "currentActivity", "$default": "" }, "className": "stack-info" }, "placement": { "x": 0, "y": 104 } }
