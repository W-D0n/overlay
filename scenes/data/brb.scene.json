{
  "id": "brb",
  "background": { "component": "DotGridBackground", "options": { "mode": "brb" } },
  "transition": {
    "type": "crossfade",
    "duration": 600,
    "easing": "easeInOut"
  },
  "layers": [
    {
      "name": "goldbar",
      "components": [
        {
          "component": "GoldBar",
          "options": {
            "position": "top",
            "opacity": 0.6
          }
        },
        {
          "component": "GoldBar",
          "options": {
            "position": "bottom"
          }
        }
      ],
      "visibility": {
        "full": true,
        "minimal": true,
        "hidden": false
      }
    },
    {
      "name": "separator",
      "components": [
        {
          "component": "Divider",
          "options": { "orientation": "vertical" },
          "placement": { "x": 1140, "y": 40, "width": 1, "height": 940 }
        }
      ],
      "visibility": { "full": true, "minimal": true, "hidden": false }
    },
    {
      "name": "message",
      "components": [
        {
          "component": "TextLabel",
          "options": {
            "text": "— Pause —",
            "className": "brb-tag label-mono wide"
          },
          "placement": { "x": 0, "y": 0 }
        },
        {
          "component": "TextLabel",
          "options": {
            "text": "D0n",
            "className": "brb-name heading-serif"
          },
          "placement": { "x": 0, "y": 47 }
        },
        {
          "component": "Divider",
          "options": {
            "className": "brb-rule-gold rule-h-gold"
          },
          "placement": { "x": 0, "y": 179, "width": 1020 }
        },
        {
          "component": "TextLabel",
          "options": {
            "text": "Retour dans quelques minutes.",
            "className": "brb-message value-serif"
          },
          "placement": { "x": 0, "y": 212 }
        },
        {
          "component": "TextLabel",
          "options": {
            "text": "On était en train de travailler",
            "className": "brb-message value-serif"
          },
          "placement": { "x": 0, "y": 273 }
        },
        {
          "component": "TextLabel",
          "options": {
            "text": "sur l'atelier.",
            "className": "brb-activity value-serif gold"
          },
          "placement": { "x": 0, "y": 334 },
          "role": "activity"
        },
        {
          "component": "Divider",
          "options": {
            "className": "brb-divider rule-h"
          },
          "placement": { "x": 0, "y": 419, "width": 1020 }
        },
        {
          "component": "TextLabel",
          "options": {
            "text": "En ce moment",
            "className": "brb-song-label label-mono"
          },
          "placement": { "x": 0, "y": 452 }
        },
        {
          "component": "TextLabel",
          "options": {
            "text": { "$bind": "currentSong", "$default": "—" },
            "className": "brb-song value-mono-gold"
          },
          "placement": { "x": 0, "y": 477 }
        }
      ],
      "visibility": {
        "full": true,
        "minimal": true,
        "hidden": false
      },
      "placement": {
        "x": 80,
        "y": 80,
        "width": 1020,
        "height": 880
      }
    },
    {
      "name": "chat",
      "components": [
        {
          "component": "TextLabel",
          "options": {
            "text": "Chat",
            "className": "brb-chat-label label-mono"
          }
        },
        {
          "component": "Divider",
          "options": {
            "className": "brb-chat-rule rule-h"
          }
        },
        {
          "component": "ChatFeed",
          "options": {
            "maxMessages": 10,
            "fontSize": "20px"
          },
          "role": "chat"
        }
      ],
      "visibility": {
        "full": true,
        "minimal": false,
        "hidden": false
      },
      "placement": {
        "x": 1174,
        "y": 80,
        "width": 706,
        "height": 780
      }
    },
    {
      "name": "stats",
      "components": [
        {
          "component": "StatBlock",
          "options": {
            "label": "DURÉE",
            "value": { "$bind": "duration" },
            "valueColor": "#C8B97A"
          }
        }
      ],
      "visibility": {
        "full": true,
        "minimal": false,
        "hidden": false
      },
      "placement": { "x": 1174, "y": 886 }
    },
    {
      "name": "next-stream",
      "components": [
        {
          "component": "TextLabel",
          "options": {
            "text": "Prochain stream",
            "className": "brb-next-label label-mono",
            "tag": "span"
          }
        },
        {
          "component": "TextLabel",
          "options": {
            "text": { "$bind": "nextStream", "$default": "À venir" },
            "className": "next-info value-serif",
            "tag": "span"
          }
        },
        {
          "component": "TextLabel",
          "options": {
            "text": { "$bind": "nextStreamTopic", "$default": "" },
            "className": "next-topic value-serif gold",
            "tag": "span"
          }
        },
        {
          "component": "TextLabel",
          "options": {
            "text": "twitch.tv/d0natelll0",
            "className": "brb-footer-link text-ghost",
            "tag": "span"
          }
        }
      ],
      "visibility": {
        "full": true,
        "minimal": false,
        "hidden": false
      },
      "placement": { "x": 0, "y": 992, "width": 1920, "height": 88 }
    }
  ]
}
