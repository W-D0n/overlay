{
  "id": "interview",
  "background": { "component": "DotGridBackground", "options": { "mode": "interview" } },
  "transition": { "type": "crossfade", "duration": 400, "easing": "easeInOut" },
  "layers": [
    {
      "name": "goldbar",
      "components": [
        { "component": "GoldBar", "options": { "position": "top" } },
        { "component": "GoldBar", "options": { "position": "bottom" } }
      ],
      "visibility": { "full": true, "minimal": true, "hidden": false }
    },
    {
      "name": "cams",
      "components": [
        { "component": "Box", "options": {}, "placement": { "x": 40, "y": 40, "width": 740, "height": 820 } },
        { "component": "Divider", "options": { "className": "int-center-rule" }, "placement": { "x": 793, "y": 40, "width": 1, "height": 900 } },
        { "component": "Box", "options": {}, "placement": { "x": 820, "y": 40, "width": 740, "height": 820 } }
      ],
      "visibility": { "full": true, "minimal": false, "hidden": false }
    },
    {
      "name": "fiches",
      "components": [
        { "component": "Box", "options": { "borderColor": "var(--border-gold)", "background": "var(--color-bg-widget)" }, "placement": { "x": 40, "y": 878, "width": 740, "height": 100 } },
        { "component": "TextLabel", "options": { "text": "D0n", "className": "int-fiche-name heading-serif", "tag": "span" }, "placement": { "x": 65, "y": 906 } },
        { "component": "Divider", "options": { "className": "int-fiche-v rule-v" }, "placement": { "x": 157, "y": 908, "width": 1, "height": 40 } },
        { "component": "TextLabel", "options": { "text": "Streamer · Développeur", "className": "int-fiche-role value-mono-gold", "tag": "span" }, "placement": { "x": 182, "y": 917 } },
        { "component": "Box", "options": { "borderColor": "var(--border-gold)", "background": "var(--color-bg-widget)" }, "placement": { "x": 820, "y": 878, "width": 740, "height": 100 } },
        { "component": "TextLabel", "options": { "text": { "$bind": "guest.name", "$default": "Invité" }, "className": "int-fiche-name heading-serif fiche-name-guest", "tag": "span" }, "placement": { "x": 845, "y": 906 } },
        { "component": "Divider", "options": { "className": "int-fiche-v rule-v" }, "placement": { "x": 964, "y": 908, "width": 1, "height": 40 } },
        { "component": "TextLabel", "options": { "text": { "$bind": "guest.role", "$default": "—" }, "className": "int-fiche-role value-mono-gold fiche-role-guest", "tag": "span" }, "placement": { "x": 989, "y": 917 } }
      ],
      "visibility": { "full": true, "minimal": false, "hidden": false }
    },
    {
      "name": "subject",
      "components": [
        { "component": "TextLabel", "options": { "text": "Sujet", "className": "int-subject-label label-mono", "tag": "span" }, "placement": { "x": 25, "y": 23 } },
        { "component": "Divider", "options": { "className": "int-subject-v rule-v" }, "placement": { "x": 96, "y": 16, "width": 1 } },
        { "component": "TextLabel", "options": { "text": { "$bind": "subjectLine", "$default": "—" }, "className": "int-subject-text value-serif", "tag": "span" }, "placement": { "x": 121, "y": 14 } }
      ],
      "visibility": { "full": true, "minimal": false, "hidden": false },
      "placement": { "x": 40, "y": 1000, "width": 1520, "height": 60 }
    },
    {
      "name": "chat",
      "components": [
        { "component": "ChatFeed", "options": { "maxMessages": 10, "fontSize": "18px" } }
      ],
      "visibility": { "full": true, "minimal": false, "hidden": false }
    },
    {
      "name": "stats",
      "components": [
        { "component": "StatBlock", "options": { "label": "DURÉE", "value": { "$bind": "duration" }, "valueColor": "#C8B97A" } }
      ],
      "visibility": { "full": true, "minimal": false, "hidden": false }
    }
  ]
}
