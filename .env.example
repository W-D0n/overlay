# .env.example — gabarit de config locale du relais (S4).
#
# Copier en `.env` (déjà dans .gitignore, jamais commité) et renseigner les vraies valeurs.
# Bun charge automatiquement `.env` au lancement de `bun relay/server.js` — pas besoin de
# les exporter manuellement à chaque fois.
#
# IMPORTANT : OVERLAY_RELAY_SECRET ici doit être EXACTEMENT la même valeur que RELAY_TOKEN
# dans obs-config.local.js (deux fichiers, un seul secret — le relais et le navigateur ne
# lisent pas les mêmes mécanismes de config).

OBS_WS_URL=ws://192.168.1.12:4455
OBS_WS_PASSWORD=
OVERLAY_RELAY_SECRET=
RELAY_PORT=4456
# Nom exact de la Browser Source overlay dans OBS (panneau Sources) — pour POST /refresh-source
# (rafraîchit son cache automatiquement, ex. après une sauvegarde depuis dotgrid-tuner.html).
OBS_BROWSER_SOURCE_NAME=Overlay Atelier
